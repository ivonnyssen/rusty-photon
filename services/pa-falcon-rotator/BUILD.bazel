load("@cr//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

exports_files(
    ["Cargo.toml"],
    visibility = ["//visibility:public"],
)

_INTRA_WORKSPACE_DEPS = [
    "//crates/rusty-photon-config:rusty-photon-config",
    "//crates/rusty-photon-driver:rusty-photon-driver",
    "//crates/rusty-photon-server-config:rusty-photon-server-config",
    "//crates/rp-auth:rp-auth",
    "//crates/rp-tls:rp-tls",
    "//crates/rusty-photon-service-lifecycle:rusty-photon-service-lifecycle",
    "//crates/rusty-photon-shared-transport:rusty-photon-shared-transport",
]

rust_library(
    name = "pa-falcon-rotator_lib",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/main.rs"],
    ),
    aliases = aliases(),
    crate_name = "pa_falcon_rotator",
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = ["//visibility:public"],
    deps = _INTRA_WORKSPACE_DEPS + all_crate_deps(normal = True),
)

rust_binary(
    name = "pa-falcon-rotator",
    srcs = ["src/main.rs"],
    aliases = aliases(),
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = ["//visibility:public"],
    deps = [":pa-falcon-rotator_lib"] + _INTRA_WORKSPACE_DEPS + all_crate_deps(normal = True),
)

# Unit tests compile the lib with `crate_features = ["mock"]` so the in-lib
# `#[cfg(all(test, feature = "mock"))]` suites in manager.rs / rotator_device.rs
# / switch_device.rs compile and run, matching the Cargo coverage job's
# `cargo test --all-features`. The default non-mock compile cfg-excluded them —
# the dominant bazel<cargo coverage gap (see docs/plans/archive/bazel-migration.md
# "Coverage under Bazel"). `crate_features` must be on the rust_test itself —
# `crate = ":..._lib_mock"` does NOT inherit the library's features. The `mock`
# module is additive and every `not(feature = "mock")` block lives in main.rs
# (outside this lib), so nothing is lost. Same pattern as `test_lib` below.
rust_test(
    name = "pa-falcon-rotator_unit_test",
    size = "medium",
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate = ":pa-falcon-rotator_lib",
    crate_features = ["mock"],
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    deps = _INTRA_WORKSPACE_DEPS + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

# Integration test targets: Cargo auto-discovers tests/*.rs as integration
# binaries, rules_rust does not. Each Cargo integration test needs its own
# rust_test entry here so `bazel test //...` runs them.
rust_test(
    name = "property_tests",
    size = "small",
    srcs = ["tests/property_tests.rs"],
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate_root = "tests/property_tests.rs",
    edition = "2021",
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    deps = [":pa-falcon-rotator_lib"] + _INTRA_WORKSPACE_DEPS + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

rust_test(
    name = "test_lib",
    size = "small",
    srcs = ["tests/test_lib.rs"],
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate_features = ["mock"],
    crate_root = "tests/test_lib.rs",
    edition = "2021",
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    deps = [":pa-falcon-rotator_lib_mock"] + _INTRA_WORKSPACE_DEPS + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

# ConformU compliance test: spawns the mock-feature binary and drives
# the ConformU CLI against it (rotator device, then switch device).
# CONFORMU_PATH must be set in the environment for the run to be active;
# without it the helper returns ConformuRun::Skipped and the test passes.
rust_test(
    name = "conformu_integration",
    size = "large",
    srcs = ["tests/conformu_integration.rs"],
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate_features = [
        "mock",
        "conformu",
    ],
    data = [":pa-falcon-rotator_mock"],
    edition = "2021",
    env = {
        "PA_FALCON_ROTATOR_BINARY": "$(rootpath :pa-falcon-rotator_mock)",
        "RUST_COVERAGE_EXTRA_OBJECTS": "$(rootpath :pa-falcon-rotator_mock)",
    },
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    rustc_env = {"CARGO_PKG_NAME": "pa-falcon-rotator"},
    tags = ["conformu"],
    deps = [
        ":pa-falcon-rotator_lib_mock",
        "//crates/bdd-infra:bdd-infra_conformu",
    ] + _INTRA_WORKSPACE_DEPS + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

# Mock-feature binary used by the conformu_integration test above. The BDD
# tests run in-process (no child spawn), but ConformU requires an external
# binary to connect to, so we need a real executable here.
rust_binary(
    name = "pa-falcon-rotator_mock",
    srcs = ["src/main.rs"],
    aliases = aliases(),
    crate_features = ["mock"],
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    rustc_env = {"CARGO_PKG_NAME": "pa-falcon-rotator"},
    deps = [":pa-falcon-rotator_lib_mock"] + _INTRA_WORKSPACE_DEPS + all_crate_deps(normal = True),
)

# BDD cucumber tests run **in-process**: each scenario builds a `BoundServer`
# on an ephemeral port and drives it via in-process Alpaca HTTP clients.
# `MockSerialPortFactory` is pulled in via the `_lib_mock` dependency below.
rust_library(
    name = "pa-falcon-rotator_lib_mock",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/main.rs"],
    ),
    aliases = aliases(),
    crate_features = ["mock"],
    crate_name = "pa_falcon_rotator",
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    deps = _INTRA_WORKSPACE_DEPS + all_crate_deps(normal = True),
)

rust_test(
    name = "bdd",
    size = "small",
    srcs = ["tests/bdd.rs"] + glob(["tests/bdd/**/*.rs"]),
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate_root = "tests/bdd.rs",
    data = ["Cargo.toml"] + glob(["tests/features/**"]),
    edition = "2021",
    env = {
        "BDD_PACKAGE_DIR": "services/pa-falcon-rotator",
    },
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    # rules_rust defaults CARGO_PKG_NAME to the crate name ("bdd"), but
    # bdd-infra derives {PKG_UPPER_SNAKE}_BINARY from it — keep it aligned
    # with the service name even though no `*_BINARY` env is read in-process.
    rustc_env = {"CARGO_PKG_NAME": "pa-falcon-rotator"},
    tags = ["bdd"],
    use_libtest_harness = False,
    # Depend on the mock-feature library so `MockSerialPortFactory` (gated
    # on `feature = "mock"`) is visible to the in-process BDD world. The
    # Cargo test uses `required-features = ["mock"]` for the same reason.
    deps = [
        ":pa-falcon-rotator_lib_mock",
        "//crates/bdd-infra",
    ] + _INTRA_WORKSPACE_DEPS + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)
