# Rusty Photon SVBony camera access (installed by rusty-photon-svbony-camera).
#
# Group-scoped device access per ADR-013 §3: make SVBony USB devices
# (VID f266) accessible to the rusty-photon service group (the account's
# own group, created with the user by every package — never plugdev, a
# Debian base-passwd group rpm-family hosts do not have) instead of a
# world-writable MODE="0666" rule. Named 90- for family consistency with
# 90-rusty-photon-qhy.rules / 90-rusty-photon-zwo.rules.
SUBSYSTEMS=="usb", ATTRS{idVendor}=="f266", GROUP="rusty-photon", MODE="0660"
# High-resolution sensors need more than the usbfs default (16 MB) for
# bulk transfers; mirrors the ZWO/QHY rule's usbfs_memory_mb bump.
ACTION=="add", SUBSYSTEMS=="usb", ATTRS{idVendor}=="f266", RUN+="/bin/sh -c 'echo 200 > /sys/module/usbcore/parameters/usbfs_memory_mb || true'"
