load("@cr//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

exports_files(
    [
        "Cargo.toml",
        "pkg/doctor.toml",
    ],
    visibility = ["//visibility:public"],
)

_INTRA_WORKSPACE_DEPS = [
    "//crates/rp-auth:rp-auth",
    "//crates/rp-catalog:rp-catalog",
    "//crates/rp-ephemeris:rp-ephemeris",
    "//crates/rp-fits:rp-fits",
    "//crates/rp-tls:rp-tls",
    "//crates/rusty-photon-config:rusty-photon-config",
    "//crates/rusty-photon-server-config:rusty-photon-server-config",
    "//crates/rusty-photon-service-lifecycle:rusty-photon-service-lifecycle",
]

# rp-plate-solver ships two Bazel variants — production-clean for
# library/binary targets and `_with_mock` for tests that need
# MockPlateSolveClient. See docs/plans/archive/bazel-migration.md
# ("Mockall mock variants") for the pattern.
_RP_PLATE_SOLVER = "//crates/rp-plate-solver:rp-plate-solver"

_RP_PLATE_SOLVER_WITH_MOCK = "//crates/rp-plate-solver:rp-plate-solver_with_mock"

# rp-guider follows the same two-variant pattern.
_RP_GUIDER = "//crates/rp-guider:rp-guider"

_RP_GUIDER_WITH_MOCK = "//crates/rp-guider:rp-guider_with_mock"

rust_library(
    name = "rp_lib",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/main.rs"],
    ),
    aliases = aliases(),
    crate_name = "rp",
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = ["//visibility:public"],
    deps = _INTRA_WORKSPACE_DEPS + [
        _RP_PLATE_SOLVER,
        _RP_GUIDER,
    ] + all_crate_deps(normal = True),
)

# Test-only twin of `rp_lib` linking the `_with_mock` plate-solver
# variant so unit tests in mcp.rs can use MockPlateSolveClient.
# Same crate_name as `rp_lib` — they are never linked into the same
# binary. rules_rust merges `crate=`'s parent deps with the test's
# own, so the test must reach the with-mock plate-solver through
# this twin (not by overriding deps on the rust_test directly,
# which produces an `E0464 multiple candidates` link conflict).
# `testonly = True` is also required here because the twin depends
# on the testonly `:rp-plate-solver_with_mock`.
rust_library(
    name = "rp_lib_with_mock",
    testonly = True,
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/main.rs"],
    ),
    aliases = aliases(),
    # `mcp/tests.rs` embeds the auto_focus V-curve fixtures via
    # `include_bytes!("../../tests/fixtures/auto_focus/*.fits")`;
    # `compile_data` makes those files visible to rustc inside
    # Bazel's compilation sandbox. Only needed on the test-twin
    # because the embeds sit inside a `#[cfg(test)] mod tests`
    # block — the production twin (`rp_lib`) skips them.
    compile_data = glob(["tests/fixtures/**"]),
    crate_name = "rp",
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    deps = _INTRA_WORKSPACE_DEPS + [
        _RP_PLATE_SOLVER_WITH_MOCK,
        _RP_GUIDER_WITH_MOCK,
    ] + all_crate_deps(normal = True),
)

rust_binary(
    name = "rp",
    srcs = ["src/main.rs"],
    aliases = aliases(),
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = ["//visibility:public"],
    deps = [":rp_lib"] + _INTRA_WORKSPACE_DEPS + [
        _RP_PLATE_SOLVER,
        _RP_GUIDER,
    ] + all_crate_deps(normal = True),
)

# Examples built by `cargo build --all-targets` (not executed in CI). Bazel
# mirrors them as rust_binary targets for `bazel build //...` parity. Both pull
# rp::imaging / rp::persistence from rp_lib; ndarray + tokio are normal deps, so
# the dep list matches the `rp` binary above.
rust_binary(
    name = "check_autofocus_fixtures",
    srcs = ["examples/check_autofocus_fixtures.rs"],
    aliases = aliases(),
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    deps = [":rp_lib"] + _INTRA_WORKSPACE_DEPS + [
        _RP_PLATE_SOLVER,
        _RP_GUIDER,
    ] + all_crate_deps(normal = True),
)

rust_binary(
    name = "gen_autofocus_fixtures",
    srcs = ["examples/gen_autofocus_fixtures.rs"],
    aliases = aliases(),
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    deps = [":rp_lib"] + _INTRA_WORKSPACE_DEPS + [
        _RP_PLATE_SOLVER,
        _RP_GUIDER,
    ] + all_crate_deps(normal = True),
)

rust_test(
    name = "rp_unit_test",
    size = "small",
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    compile_data = ["pkg/doctor.toml"],
    crate = ":rp_lib_with_mock",
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    deps = _INTRA_WORKSPACE_DEPS + [
        _RP_PLATE_SOLVER_WITH_MOCK,
        _RP_GUIDER_WITH_MOCK,
    ] + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

rust_test(
    name = "bdd",
    # ~250 cucumber scenarios, most of them feature-tagged @serial (shared
    # OmniSim device state), so a single process runs them nearly serially:
    # ~344 s locally, up to ~12 min on the Windows CI runner. "large" gives
    # each shard a 15 min budget so occasional CI slowness doesn't time out.
    size = "large",
    srcs = ["tests/bdd.rs"] + glob(["tests/bdd/**/*.rs"]),
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate_root = "tests/bdd.rs",
    data = [
        "Cargo.toml",
        ":rp",
        "//services/calibrator-flats",
        "//services/sky-survey-camera",
    ] + glob(["tests/features/**"]),
    edition = "2021",
    env = {
        "BDD_PACKAGE_DIR": "services/rp",
        "CALIBRATOR_FLATS_BINARY": "$(rootpath //services/calibrator-flats:calibrator-flats)",
        "RP_BINARY": "$(rootpath :rp)",
        "SKY_SURVEY_CAMERA_BINARY": "$(rootpath //services/sky-survey-camera:sky-survey-camera)",
        "RUST_COVERAGE_EXTRA_OBJECTS": "$(rootpath //services/calibrator-flats:calibrator-flats):$(rootpath :rp):$(rootpath //services/sky-survey-camera:sky-survey-camera)",
    },
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    # rules_rust defaults CARGO_PKG_NAME to the crate name ("bdd"), but
    # bdd-infra derives {PKG_UPPER_SNAKE}_BINARY from it — it must be the
    # service name.
    rustc_env = {"CARGO_PKG_NAME": "rp"},
    # Split the suite into parallel shard processes. bdd_main! advertises
    # sharding support (TEST_SHARD_STATUS_FILE) and tests/bdd.rs routes the
    # scenario filter through bdd_infra::sharding, so each shard runs a
    # deterministic slice of the scenarios against its own private OmniSim
    # (--multi-instance + dynamic port + per-instance OMNISIM_SETTINGS_DIR;
    # see crates/bdd-infra/src/rp_harness/omnisim.rs). @serial semantics are
    # preserved *within* each shard.
    shard_count = 8,
    # `resources:omnisim:1`: every OmniSim-spawning BDD action (each shard of
    # this target, and the other three OmniSim suites) takes one token from
    # the `omnisim` pool defined in .bazelrc. Since #467 the harness spawns a
    # private OmniSim per test process (--multi-instance + dynamic port +
    # per-instance OMNISIM_SETTINGS_DIR — the fork env var that re-roots the
    # profile store on every platform; XDG_CONFIG_HOME only worked on Linux),
    # so the pool is sized generously on every OS and these actions genuinely
    # run in parallel; it remains only as a throttle to grab if OmniSim
    # concurrency ever turns flaky.
    # Any new OmniSim-spawning BDD target MUST also carry this tag.
    tags = [
        "bdd",
        "resources:omnisim:1",
    ],
    use_libtest_harness = False,
    deps = [
        ":rp_lib",
        "//crates/bdd-infra:bdd-infra_rp_harness_tls_auth",
    ] + _INTRA_WORKSPACE_DEPS + [
        _RP_PLATE_SOLVER,
        _RP_GUIDER,
    ] + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)
