{
  "version": 1,
  "name": "deep-sky",
  "description": "Classic multi-target deep-sky imaging session, addressed by optical train: unpark and start tracking, then a dispatch loop that asks rp's planner for the best target after every frame — changing filter whenever the recommended one differs from the wheel's current, acquiring on target change (stop guiding if active, slew, optional plate-solve centering, optional auto-focus, optional start of guiding), capturing one frame per pass, recording it via record_exposure so rp's progress counters rotate exposure plans, balance targets, and end the session once every integration goal is met, and dithering every dither_every recorded frames — with reactive refocusing, meridian-flip handling, and rp's guide-focus-watch events answered by a guide-only metric auto_focus (guide_focus_degraded) or the full refocus_train (guide_focus_escalation), ending at the frame budget or when the planner declares the session over (end_of_session), stopping guiding and optionally parking. The single train_id parameter names the imaging train: rp resolves the camera, filter wheel, and focuser through it, and auto-focus sweep geometry comes from the train's auto_focus config block. get_next_target supplies filter/duration_secs from the target's first incomplete exposures[] entry with the exposure/filter parameters as fallback for plan-less targets — see docs/services/session-runner.md § deep_sky.json.",
  "parameters": {
    "train_id": { "type": "string", "required": true },
    "exposure": { "type": "duration", "default": "300s" },
    "max_frames": { "type": "integer", "default": 0 },
    "filter": { "type": "string", "default": "" },
    "centering": { "type": "boolean", "default": true },
    "centering_exposure": { "type": "duration", "default": "5s" },
    "centering_tolerance_arcsec": { "type": "number", "default": 60 },
    "centering_max_attempts": { "type": "integer", "default": 5 },
    "focus": { "type": "boolean", "default": true },
    "focus_min_area": { "type": "integer", "default": 5 },
    "focus_max_area": { "type": "integer", "default": 65536 },
    "refocus_every": { "type": "integer", "default": 0 },
    "refocus_hfr_factor": { "type": "number", "default": 1.2 },
    "guide": { "type": "boolean", "default": false },
    "dither_every": { "type": "integer", "default": 0 },
    "meridian_margin": { "type": "number", "default": 300 },
    "park_on_finish": { "type": "boolean", "default": true }
  },
  "estimated_duration": "8h",
  "max_duration": "14h",
  "triggers": [
    {
      "id": "refocus-after-frames",
      "on": { "event": "exposure_complete" },
      "when": "params.focus == true && params.refocus_every > 0 && session.frames_since_focus >= params.refocus_every",
      "while": "session.imaging == true",
      "do": [
        {
          "try": [
            {
              "tool": "auto_focus",
              "args": { "train_id": { "$expr": "params.train_id" } }
            },
            { "set": { "session.last_focus_hfr": "result.best_hfr" } }
          ],
          "catch": [
            {
              "log": {
                "level": "info",
                "message": "scheduled refocus failed; continuing at the current focus position",
                "values": { "error": "error.message" }
              }
            }
          ]
        },
        { "set": { "session.frames_since_focus": "0" } }
      ]
    },
    {
      "id": "refocus-on-hfr-degradation",
      "on": { "event": "exposure_complete" },
      "when": "params.focus == true && params.refocus_hfr_factor > 0 && has(session.last_focus_hfr)",
      "while": "session.imaging == true",
      "cooldown": "15m",
      "do": [
        {
          "tool": "measure_basic",
          "args": {
            "document_id": { "$expr": "event.document_id" },
            "min_area": { "$expr": "params.focus_min_area" },
            "max_area": { "$expr": "params.focus_max_area" }
          }
        },
        {
          "if": "result.hfr != null && result.hfr > session.last_focus_hfr * params.refocus_hfr_factor",
          "then": [
            {
              "try": [
                {
                  "tool": "auto_focus",
                  "args": { "train_id": { "$expr": "params.train_id" } }
                },
                { "set": { "session.last_focus_hfr": "result.best_hfr" } }
              ],
              "catch": [
                {
                  "log": {
                    "level": "info",
                    "message": "HFR-triggered refocus failed; continuing at the current focus position",
                    "values": { "error": "error.message" }
                  }
                }
              ]
            },
            { "set": { "session.frames_since_focus": "0" } }
          ]
        }
      ]
    },
    {
      "id": "flip-when-due",
      "on": { "poll": { "tool": "get_meridian_status", "args": {}, "interval": "30s" } },
      "when": "event.time_to_flip_seconds != null && event.time_to_flip_seconds < params.meridian_margin",
      "while": "session.imaging == true",
      "do": [
        {
          "log": {
            "level": "info",
            "message": "meridian flip due — re-slewing to the target",
            "values": { "time_to_flip_seconds": "event.time_to_flip_seconds" }
          }
        },
        {
          "if": "session.guiding == true",
          "then": [
            {
              "try": [{ "tool": "stop_guiding", "args": {} }],
              "catch": [
                {
                  "log": {
                    "level": "info",
                    "message": "stop_guiding failed before the flip; flipping anyway",
                    "values": { "error": "error.message" }
                  }
                }
              ]
            },
            {
              "set": {
                "session.flip_restart_guiding": "true",
                "session.guiding": "false"
              }
            }
          ]
        },
        {
          "tool": "slew",
          "args": {
            "ra": { "$expr": "session.target_ra" },
            "dec": { "$expr": "session.target_dec" }
          }
        },
        {
          "if": "params.centering == true",
          "then": [
            {
              "tool": "center_on_target",
              "args": {
                "train_id": { "$expr": "params.train_id" },
                "ra": { "$expr": "session.target_ra" },
                "dec": { "$expr": "session.target_dec" },
                "duration": { "$expr": "params.centering_exposure" },
                "tolerance_arcsec": { "$expr": "params.centering_tolerance_arcsec" },
                "max_attempts": { "$expr": "params.centering_max_attempts" }
              }
            }
          ]
        },
        {
          "if": "session.flip_restart_guiding == true",
          "then": [
            {
              "tool": "start_guiding",
              "args": {},
              "retry": { "max_attempts": 3, "backoff": "30s" }
            },
            {
              "set": {
                "session.guiding": "true",
                "session.flip_restart_guiding": "false"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "guide-af-on-degraded",
      "on": { "event": "guide_focus_degraded" },
      "when": "params.guide == true && event.train_id != null",
      "do": [
        {
          "try": [
            {
              "tool": "auto_focus",
              "args": { "train_id": { "$expr": "event.train_id" } }
            }
          ],
          "catch": [
            {
              "log": {
                "level": "info",
                "message": "guide-only refocus failed; the watch will escalate if the trend persists",
                "values": { "error": "error.message" }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "refocus-on-escalation",
      "on": { "event": "guide_focus_escalation" },
      "when": "params.guide == true && event.train_id != null",
      "do": [
        {
          "try": [
            {
              "tool": "refocus_train",
              "args": {
                "train_id": { "$expr": "event.train_id" },
                "reason": "guide_focus_escalation"
              }
            },
            { "set": { "session.frames_since_focus": "0" } }
          ],
          "catch": [
            {
              "log": {
                "level": "info",
                "message": "escalated refocus failed; continuing at the current focus position",
                "values": { "error": "error.message" }
              }
            }
          ]
        }
      ]
    }
  ],
  "root": {
    "sequence": [
      {
        "set": {
          "session.total_frames": "has(session.total_frames) ? session.total_frames : 0",
          "session.frames_since_focus": "has(session.frames_since_focus) ? session.frames_since_focus : 0",
          "session.frames_since_dither": "has(session.frames_since_dither) ? session.frames_since_dither : 0",
          "session.report.total_frames": "has(session.report.total_frames) ? session.report.total_frames : 0",
          "session.current_filter": "has(session.current_filter) ? session.current_filter : ''"
        }
      },
      {
        "id": "recovery-reacquire",
        "if": "has(params._recovery.reason)",
        "then": [
          {
            "log": {
              "level": "info",
              "message": "resuming after an interruption — the target will be re-acquired",
              "values": { "reason": "params._recovery.reason" }
            }
          },
          {
            "set": {
              "session.target_name": "null",
              "session.imaging": "false",
              "session.guiding": "false"
            }
          }
        ]
      },
      { "tool": "unpark", "args": {} },
      { "tool": "set_tracking", "args": { "enabled": true } },
      {
        "id": "dispatch",
        "repeat": { "while": "session.session_over != true", "max_iterations": 20000 },
        "body": [
          { "tool": "get_next_target", "args": {} },
          {
            "if": "result.reason == 'end_of_session'",
            "then": [
              { "log": { "level": "info", "message": "the planner declared the session over" } },
              { "set": { "session.session_over": "true" } }
            ],
            "else": [
              {
                "if": "result.target == null",
                "then": [
                  { "set": { "session.imaging": "false" } },
                  {
                    "log": {
                      "message": "no viable target — waiting before re-asking the planner",
                      "values": { "reason": "result.reason" }
                    }
                  },
                  { "wait": { "duration": "5m" } }
                ],
                "else": [
                  {
                    "set": {
                      "session.pass_target": "result.target.name",
                      "session.pass_ra": "result.target.ra_hours",
                      "session.pass_dec": "result.target.dec_degrees",
                      "session.pass_filter": "result.duration_secs != null ? (result.filter != null ? result.filter : '') : params.filter",
                      "session.pass_duration": "result.duration_secs != null ? humantime(result.duration_secs) : params.exposure"
                    }
                  },
                  {
                    "id": "filter-on-change",
                    "if": "session.pass_filter != '' && session.pass_filter != session.current_filter",
                    "then": [
                      {
                        "tool": "set_filter",
                        "args": {
                          "train_id": { "$expr": "params.train_id" },
                          "filter_name": { "$expr": "session.pass_filter" }
                        }
                      },
                      { "set": { "session.current_filter": "session.pass_filter" } }
                    ]
                  },
                  {
                    "id": "acquire-on-target-change",
                    "if": "session.target_name != session.pass_target",
                    "then": [
                      { "set": { "session.imaging": "false" } },
                      {
                        "if": "session.guiding == true",
                        "then": [
                          {
                            "try": [{ "tool": "stop_guiding", "args": {} }],
                            "catch": [
                              {
                                "log": {
                                  "level": "info",
                                  "message": "stop_guiding failed before the target switch; slewing anyway",
                                  "values": { "error": "error.message" }
                                }
                              }
                            ]
                          },
                          { "set": { "session.guiding": "false" } }
                        ]
                      },
                      {
                        "log": {
                          "level": "info",
                          "message": "acquiring target",
                          "values": {
                            "target": "session.pass_target",
                            "filter": "session.pass_filter",
                            "duration": "session.pass_duration"
                          }
                        }
                      },
                      {
                        "tool": "slew",
                        "args": {
                          "ra": { "$expr": "session.pass_ra" },
                          "dec": { "$expr": "session.pass_dec" }
                        }
                      },
                      {
                        "if": "params.centering == true",
                        "then": [
                          {
                            "tool": "center_on_target",
                            "args": {
                              "train_id": { "$expr": "params.train_id" },
                              "ra": { "$expr": "session.pass_ra" },
                              "dec": { "$expr": "session.pass_dec" },
                              "duration": { "$expr": "params.centering_exposure" },
                              "tolerance_arcsec": { "$expr": "params.centering_tolerance_arcsec" },
                              "max_attempts": { "$expr": "params.centering_max_attempts" }
                            }
                          }
                        ]
                      },
                      {
                        "if": "params.focus == true",
                        "then": [
                          {
                            "try": [
                              {
                                "tool": "auto_focus",
                                "args": { "train_id": { "$expr": "params.train_id" } }
                              },
                              { "set": { "session.last_focus_hfr": "result.best_hfr" } }
                            ],
                            "catch": [
                              {
                                "log": {
                                  "level": "info",
                                  "message": "auto-focus failed; continuing at the current focus position",
                                  "values": { "error": "error.message" }
                                }
                              }
                            ]
                          },
                          { "set": { "session.frames_since_focus": "0" } }
                        ]
                      },
                      {
                        "if": "params.guide == true",
                        "then": [
                          {
                            "tool": "start_guiding",
                            "args": {},
                            "retry": { "max_attempts": 3, "backoff": "30s" }
                          }
                        ]
                      },
                      {
                        "set": {
                          "session.target_name": "session.pass_target",
                          "session.target_ra": "session.pass_ra",
                          "session.target_dec": "session.pass_dec",
                          "session.imaging": "true",
                          "session.guiding": "params.guide == true"
                        }
                      }
                    ]
                  },
                  {
                    "id": "light-frame",
                    "tool": "capture",
                    "args": {
                      "train_id": { "$expr": "params.train_id" },
                      "duration": { "$expr": "session.pass_duration" }
                    }
                  },
                  {
                    "id": "record-light-frame",
                    "try": [
                      {
                        "tool": "record_exposure",
                        "args": {
                          "target": { "$expr": "session.target_name" },
                          "filter": { "$expr": "session.pass_filter" }
                        }
                      }
                    ],
                    "catch": [
                      {
                        "log": {
                          "level": "info",
                          "message": "record_exposure failed; the planner will not see this frame",
                          "values": { "error": "error.message" }
                        }
                      }
                    ]
                  },
                  {
                    "set": {
                      "session.total_frames": "session.total_frames + 1",
                      "session.frames_since_focus": "session.frames_since_focus + 1",
                      "session.frames_since_dither": "session.frames_since_dither + 1"
                    }
                  },
                  { "set": { "session.report.total_frames": "session.total_frames" } },
                  {
                    "id": "dither-on-cadence",
                    "if": "params.guide == true && params.dither_every > 0 && session.frames_since_dither >= params.dither_every",
                    "then": [
                      {
                        "try": [{ "tool": "dither", "args": {} }],
                        "catch": [
                          {
                            "log": {
                              "level": "info",
                              "message": "dither failed; continuing undithered",
                              "values": { "error": "error.message" }
                            }
                          }
                        ]
                      },
                      { "set": { "session.frames_since_dither": "0" } }
                    ]
                  },
                  {
                    "if": "params.max_frames > 0 && session.total_frames >= params.max_frames",
                    "then": [
                      {
                        "log": {
                          "level": "info",
                          "message": "frame budget reached — ending the session",
                          "values": { "total_frames": "session.total_frames" }
                        }
                      },
                      { "set": { "session.session_over": "true" } }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      { "set": { "session.imaging": "false" } },
      {
        "log": {
          "level": "info",
          "message": "session over — shutting down",
          "values": {
            "total_frames": "session.total_frames",
            "dispatch_converged": "result.converged"
          }
        }
      },
      {
        "id": "stop-guiding-on-shutdown",
        "if": "session.guiding == true",
        "then": [
          {
            "try": [{ "tool": "stop_guiding", "args": {} }],
            "catch": [
              {
                "log": {
                  "level": "info",
                  "message": "stop_guiding failed at shutdown; parking anyway",
                  "values": { "error": "error.message" }
                }
              }
            ]
          },
          { "set": { "session.guiding": "false" } }
        ]
      },
      {
        "if": "params.park_on_finish == true",
        "then": [{ "tool": "park", "args": {} }]
      }
    ]
  }
}
