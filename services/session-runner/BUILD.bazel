load("@cr//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

exports_files(
    ["Cargo.toml"],
    visibility = ["//visibility:public"],
)

_INTRA_WORKSPACE_DEPS = [
    "//crates/rusty-photon-config:rusty-photon-config",
    "//crates/rusty-photon-service-lifecycle:rusty-photon-service-lifecycle",
]

rust_library(
    name = "session-runner_lib",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = ["src/main.rs"],
    ),
    aliases = aliases(),
    crate_name = "session_runner",
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = ["//visibility:public"],
    deps = _INTRA_WORKSPACE_DEPS + all_crate_deps(normal = True),
)

rust_binary(
    name = "session-runner",
    srcs = ["src/main.rs"],
    aliases = aliases(),
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = ["//visibility:public"],
    deps = [":session-runner_lib"] + _INTRA_WORKSPACE_DEPS + all_crate_deps(normal = True),
)

rust_test(
    name = "session-runner_unit_test",
    size = "small",
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    # The schema-agreement suite embeds the published schema via
    # include_str!("../../schema/workflow-v1.schema.json"), and the
    # validation corpus embeds the shipped calibrator_flats.json the
    # same way.
    compile_data = ["schema/workflow-v1.schema.json"] + glob(["workflows/*.json"]),
    crate = ":session-runner_lib",
    # The golden-document suite walks workflows/ at run time (via
    # TEST_SRCDIR under Bazel) so an unwired future document cannot slip
    # past validation.
    data = glob(["workflows/*.json"]),
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    deps = _INTRA_WORKSPACE_DEPS + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

# BDD cucumber suite. Drives workflow documents end-to-end through three
# spawned processes: OmniSim (via OMNISIM_PATH, forwarded by the CI
# `build:ci --test_env`), rp (RP_BINARY), and session-runner itself
# (SESSION_RUNNER_BINARY). Uses bdd-infra's rp-harness variant — the same
# shared harness the rp and calibrator-flats suites use; the scenarios are
# the port of calibrator-flats' suite onto the shipped
# workflows/calibrator_flats.json document. A local
# `bazel test //services/session-runner:bdd` needs OmniSim installed and
# OMNISIM_PATH set, like any rp_harness BDD target.
rust_test(
    name = "bdd",
    # Spawns three processes per scenario; generous timeout. The deep-sky
    # scenarios drive real-speed OmniSim slews, so the suite is ~6 min of
    # mostly-@serial wall clock in one process.
    size = "large",
    srcs = ["tests/bdd.rs"] + glob(["tests/bdd/**/*.rs"]),
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate_root = "tests/bdd.rs",
    data = [
        "Cargo.toml",
        ":session-runner",
        "//services/rp",
    ] + glob([
        "tests/features/**",
        "tests/fixtures/**",
        "workflows/*.json",
    ]),
    edition = "2021",
    env = {
        "BDD_PACKAGE_DIR": "services/session-runner",
        "SESSION_RUNNER_BINARY": "$(rootpath :session-runner)",
        "RP_BINARY": "$(rootpath //services/rp:rp)",
        "RUST_COVERAGE_EXTRA_OBJECTS": "$(rootpath :session-runner):$(rootpath //services/rp:rp)",
    },
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    # bdd-infra derives {PKG_UPPER_SNAKE}_BINARY from CARGO_PKG_NAME, so it must
    # be the service name (rules_rust would otherwise use the crate name "bdd").
    rustc_env = {"CARGO_PKG_NAME": "session-runner"},
    # Split into parallel shard processes, same mechanism as rp:bdd:
    # bdd_main! advertises sharding support and tests/bdd.rs routes the
    # scenario filter through bdd_infra::sharding; each shard runs its
    # deterministic slice against its own private OmniSim.
    shard_count = 8,
    # `resources:omnisim:1`: see the longer note in services/rp/BUILD.bazel.
    # Each OmniSim-spawning BDD action takes one token from the `omnisim`
    # pool (.bazelrc, sized generously on every OS): the harness gives every
    # test process a private OmniSim — --multi-instance + dynamic port +
    # per-instance OMNISIM_SETTINGS_DIR — so the suites run in parallel; the
    # pool is only a throttle to grab if that ever turns flaky.
    tags = [
        "bdd",
        "resources:omnisim:1",
    ],
    use_libtest_harness = False,
    deps = [
        ":session-runner_lib",
        "//crates/bdd-infra:bdd-infra_rp_harness",
    ] + _INTRA_WORKSPACE_DEPS + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)
