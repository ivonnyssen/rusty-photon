<?xml version="1.0" encoding="utf-8"?>
<!--
  rusty-photon-qhy-camera — Windows service fragment (suite MSI; ADR-015).
  Port 11121/tcp. The fragment contract (service name, exe rename,
  failure actions + failure-actions flag, firewall port, demand-start set) is
  asserted by scripts/check-pkg-assets.sh.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">
  <Fragment>
    <ComponentGroup Id="QhyCameraComponents" Directory="INSTALLFOLDER">
      <Component Id="QhyCameraExe">
        <File Id="QhyCameraExeFile" Name="rusty-photon-qhy-camera.exe" Source="!(bindpath.bin)\qhy-camera.exe" KeyPath="yes" />
        <ServiceInstall Id="QhyCameraService"
                        Name="rusty-photon-qhy-camera"
                        DisplayName="rusty-photon-qhy-camera"
                        Description="ASCOM Alpaca Camera and FilterWheel driver for QHYCCD cameras. Requires QHY's All-in-One driver pack (provides qhyccd.dll)."
                        Start="auto"
                        Type="ownProcess"
                        ErrorControl="normal"
                        Account="LocalSystem"
                        Arguments="--service"
                        Vital="yes">
          <!-- systemd Restart=on-failure / RestartSec=5 translation (ADR-015
               decision 2): restart after 5 s on every failure, indefinitely
               (failure count resets daily). -->
          <util:ServiceConfig FirstFailureActionType="restart"
                              SecondFailureActionType="restart"
                              ThirdFailureActionType="restart"
                              RestartServiceDelayInSeconds="5"
                              ResetPeriodInDays="1" />
          <!-- SERVICE_CONFIG_FAILURE_ACTIONS_FLAG: the SCM wrapper reports a
               failed run closure as SERVICE_STOPPED + ServiceSpecific(1) (see
               rusty-photon-service-lifecycle runner.rs), which only counts as
               a failure — and triggers the restart actions above — with this
               flag set. Without it the serial drivers' eager-validation exits
               would stop the service permanently. -->
          <ServiceConfig FailureActionsWhen="failedToStopOrReturnedError"
                         OnInstall="yes"
                         OnReinstall="yes" />
        </ServiceInstall>
        <ServiceControl Id="QhyCameraServiceControl"
                        Name="rusty-photon-qhy-camera"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
        <!-- Alpaca/HTTP over the LAN is the service's whole point; Windows
             Firewall blocks inbound by default. Scope=any, not localSubnet:
             multi-subnet observatory networks are the norm here (Linux ships
             no firewall config at all — parity is "reachable"). -->
        <fw:FirewallException Id="QhyCameraFirewall"
                              Name="rusty-photon-qhy-camera"
                              Description="Inbound TCP for the rusty-photon-qhy-camera service (port 11121)"
                              Port="11121"
                              Protocol="tcp"
                              Scope="any" />
      </Component>
      <!-- ADR-013: qhyccd.dll is proprietary and NEVER shipped. The exe
           delay-loads it (services/qhy-camera/build.rs) and a startup
           preflight probes the QHY All-in-One pack's install locations; on a
           box without the pack the service logs an actionable pointer and
           exits cleanly (SCM restarts it every 5 s until the pack appears —
           the same contract as a missing serial device). The Start-Menu
           shortcut below runs the interactive `doctor` diagnosis, which a
           session-0 service cannot do (it can open QHY's download page in a
           browser). cmd /k keeps the console open after the report. -->
      <Component Id="QhyCameraDoctorShortcut" Directory="RustyPhotonMenuFolder">
        <Shortcut Id="QhyCameraDoctorShortcutFile"
                  Name="QHY Camera Doctor"
                  Description="Diagnose QHY All-in-One driver pack / qhyccd.dll presence and SDK version"
                  Target="[System64Folder]cmd.exe"
                  Arguments="/k &quot;&quot;[INSTALLFOLDER]rusty-photon-qhy-camera.exe&quot; doctor&quot;"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveRustyPhotonMenuFolder" On="uninstall" />
        <RegistryValue Root="HKLM"
                       Key="Software\rusty-photon"
                       Name="QhyCameraDoctorShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
