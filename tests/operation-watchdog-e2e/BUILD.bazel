load("@cr//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

exports_files(
    ["Cargo.toml"],
    visibility = ["//visibility:public"],
)

# Doc-only library: this crate exists solely to host the BDD suite below. It
# carries no code, but a Bazel target keeps it in the build graph (parity gate)
# and matches the Cargo lib target.
rust_library(
    name = "operation-watchdog-e2e",
    srcs = glob(["src/**/*.rs"]),
    aliases = aliases(),
    crate_name = "operation_watchdog_e2e",
    edition = "2021",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = ["//visibility:public"],
    deps = all_crate_deps(normal = True),
)

# End-to-end BDD suite: spawns OmniSim, a real rp (RP_BINARY), and a real
# sentinel (SENTINEL_BINARY), plus an in-process plate-solver stub, and drives
# the operation watchdog through wedge -> escalation -> corrective ladder. Uses
# bdd-infra's rp-harness variant, like rp:bdd and calibrator-flats:bdd. A local
# `bazel test //tests/operation-watchdog-e2e:bdd` needs OmniSim installed and
# OMNISIM_PATH set, like any rp_harness BDD target.
rust_test(
    name = "bdd",
    # Spawns up to three processes per scenario with real timers; generous size.
    size = "large",
    srcs = ["tests/bdd.rs"] + glob(["tests/bdd/**/*.rs"]),
    aliases = aliases(
        normal_dev = True,
        proc_macro_dev = True,
    ),
    crate_root = "tests/bdd.rs",
    data = [
        "Cargo.toml",
        "//services/rp",
        "//services/sentinel",
    ] + glob(["tests/features/**"]),
    edition = "2021",
    env = {
        "BDD_PACKAGE_DIR": "tests/operation-watchdog-e2e",
        "RP_BINARY": "$(rootpath //services/rp:rp)",
        "SENTINEL_BINARY": "$(rootpath //services/sentinel:sentinel)",
        "RUST_COVERAGE_EXTRA_OBJECTS": "$(rootpath //services/rp:rp):$(rootpath //services/sentinel:sentinel)",
    },
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    # `resources:omnisim:1`: see the longer note in services/rp/BUILD.bazel.
    # Each OmniSim-spawning BDD action takes one token from the `omnisim`
    # pool (.bazelrc): sized generously on Linux/macOS — the harness gives
    # every test process a private OmniSim, so the suites run in parallel —
    # and 1 on Windows, where OmniSim's %USERPROFILE%\.ASCOM profile store
    # can't be isolated per instance.
    tags = [
        "bdd",
        "resources:omnisim:1",
    ],
    use_libtest_harness = False,
    deps = [
        "//crates/bdd-infra:bdd-infra_rp_harness",
    ] + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)
