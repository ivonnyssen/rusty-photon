+// rusty-photon patch (process_wrapper_read_retry): on Windows CI, opening an
+// existing, readable runfile occasionally fails with a transient
+// ERROR_ACCESS_DENIED / ERROR_SHARING_VIOLATION (the same file reads fine
+// moments later). Retry briefly before giving up, log each retry so
+// occurrences stay countable in test logs, and append the path's filesystem
+// state to a final failure so a persistent denial is diagnosable from the
+// error message alone.
+fn open_readable(path: &str) -> Result<File, String> {
+    const ATTEMPTS: u32 = 3;
+    let mut attempt = 1;
+    loop {
+        match File::open(path) {
+            Ok(file) => return Ok(file),
+            Err(err) => {
+                let transient = cfg!(windows) && matches!(err.raw_os_error(), Some(5) | Some(32));
+                if !transient || attempt == ATTEMPTS {
+                    return Err(format!("{} [{}]", err, describe_path_state(path)));
+                }
+                eprintln!(
+                    "process_wrapper: transient error opening {path:?} (attempt {attempt}/{ATTEMPTS}): {err}; retrying"
+                );
+                sleep(Duration::from_millis(100 * u64::from(attempt)));
+                attempt += 1;
+            }
+        }
+    }
+}
+
+fn describe_path_state(path: &str) -> String {
+    let describe = |p: &Path| match std::fs::symlink_metadata(p) {
+        Ok(m) => {
+            let t = m.file_type();
+            format!(
+                "{:?}: file={} dir={} symlink={} len={}",
+                p,
+                t.is_file(),
+                t.is_dir(),
+                t.is_symlink(),
+                m.len()
+            )
+        }
+        Err(e) => format!("{p:?}: metadata unavailable ({e})"),
+    };
+    let path = Path::new(path);
+    match path.parent() {
+        Some(parent) if parent != Path::new("") => {
+            format!("{}; {}", describe(path), describe(parent))
+        }
+        _ => describe(path),
+    }
+}
