--- a/rust/private/rustdoc/rustdoc_test_writer.rs
+++ b/rust/private/rustdoc/rustdoc_test_writer.rs
@@ -226,10 +226,42 @@
                 .for_each(|substring| stripped_arg = stripped_arg.replace(substring, ""));
             stripped_arg
         })
-        .map(|arg| format!("'{arg}'"))
+        // rusty-photon patch (rustdoc_test_windows_external_repo_path): every
+        // argument is routed through the RF() resolver defined below. Bazel
+        // hands cross-repo runfiles to this argv as bare `..`-relative
+        // short_paths (e.g.
+        // `../rules_rust+/util/process_wrapper/process_wrapper.exe`), which
+        // resolve neither from this script's cwd (the `_main` runfiles
+        // subdirectory) nor reliably through the sibling `external -> ..\\`
+        // symlink: on remote-cache-hit builds the runfiles-tree entry for an
+        // exec-configuration tool can be absent or dangling on Windows. RF
+        // looks the path up in the runfiles MANIFEST and invokes the absolute
+        // execroot target instead, sidestepping the tree; the `external/`
+        // rewrite remains as the fallback when no manifest exists, and every
+        // miss prints a Write-Warning so a failure names the exact gap.
+        .map(|arg| format!("(RF '{arg}')"))
         .collect::<Vec<String>>()
         .join(" ");
 
+    let rf_fn = concat!(
+        "function RF($p) { ",
+        "if ($p -notmatch '^\\.\\.[\\\\/]') { return $p } ; ",
+        "$rel = $p.Substring(3) -replace '\\\\','/' ; ",
+        "$mf = $env:RUNFILES_MANIFEST_FILE ; ",
+        "if ((-not $mf -or -not (Test-Path $mf)) -and $env:TEST_SRCDIR) { $mf = Join-Path $env:TEST_SRCDIR 'MANIFEST' } ; ",
+        "if ($mf -and (Test-Path $mf)) { ",
+        "foreach ($l in (Get-Content $mf)) { ",
+        "$i = $l.IndexOf(' ') ; ",
+        "if ($i -gt 0 -and $l.Substring(0, $i) -eq $rel) { ",
+        "$t = $l.Substring($i + 1) ; ",
+        "if (Test-Path $t) { return $t } ; ",
+        "Write-Warning ('runfiles manifest maps ' + $rel + ' to missing ' + $t) ",
+        "} } } ; ",
+        "$fb = 'external/' + $rel ; ",
+        "if (-not (Test-Path $fb)) { Write-Warning ('runfile not found via manifest or external/: ' + $rel) } ; ",
+        "return $fb }",
+    );
+
     let content = [
         "@ECHO OFF".to_owned(),
         "".to_owned(),
@@ -239,7 +271,7 @@
         "powershell.exe -c \"if (!(Test-Path .\\external)) { New-Item -Path .\\external -ItemType SymbolicLink -Value ..\\ }\""
