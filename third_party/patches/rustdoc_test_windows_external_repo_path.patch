 fn write_test_runner_windows(
     path: &Path,
     env: &BTreeMap<String, String>,
     argv: &[String],
     strip_substrings: &[String],
 ) {
     let env_str = env
         .iter()
         .map(|(key, val)| format!("$env:{key}='{val}'"))
         .collect::<Vec<String>>()
         .join(" ; ");
 
     let argv_str = argv
         .iter()
         // Remove any substrings found in the argument
         .map(|arg| {
             let mut stripped_arg = arg.to_owned();
             strip_substrings
                 .iter()
                 .for_each(|substring| stripped_arg = stripped_arg.replace(substring, ""));
             stripped_arg
         })
+        // rusty-photon patch (rustdoc_test_windows_external_repo_path): a bare
+        // `..`-relative cross-repo runfile path (Bazel's standard
+        // `File.short_path` convention, e.g.
+        // `../rules_rust+/util/process_wrapper/process_wrapper.exe`) does not
+        // reliably resolve from this script's cwd (the `_main` runfiles
+        // subdirectory) under unsandboxed/local test execution on Windows --
+        // the underlying gap tracked by bazelbuild/bazel#5926. The script
+        // below already creates an `external -> ..\` symlink for exactly this
+        // class of problem (see its TODO comment), but this argv never routed
+        // through it. Rewrite any `..`-prefixed argument to go through that
+        // symlink instead of the raw `..` traversal, so it actually benefits
+        // from the workaround.
+        .map(|arg| match arg.strip_prefix("../") {
+            Some(rest) => format!("external/{rest}"),
+            None => match arg.strip_prefix("..\\") {
+                Some(rest) => format!("external\\{rest}"),
+                None => arg,
+            },
+        })
         .map(|arg| format!("'{arg}'"))
         .collect::<Vec<String>>()
         .join(" ");
 
     let content = [
         "@ECHO OFF".to_owned(),
         "".to_owned(),
         // TODO: Instead of creating a symlink to mimic the behavior of
         // --legacy_external_runfiles, this rule should be able to correctly
         // sanitize the action args to run in a runfiles without this link.
         "powershell.exe -c \"if (!(Test-Path .\\external)) { New-Item -Path .\\external -ItemType SymbolicLink -Value ..\\ }\""
             .to_owned(),
         "".to_owned(),
         format!("powershell.exe -c \"{env_str} ; & {argv_str}\""),
         "".to_owned(),
     ];
 
     fs::write(path, content.join("\n")).expect("Failed to write test runner");
 }
 
